{
  "name": "copilot-cost-tracker",
  "displayName": "GitHub Copilot Cost Tracker",
  "description": "Track GitHub Copilot token usage and costs in real-time with a sidebar dashboard and status bar.",
  "version": "0.2.2",
  "publisher": "ervi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/erviAI/cost-research"
  },
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI"
  ],
  "keywords": [
    "copilot",
    "cost",
    "tokens",
    "usage",
    "tracking"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "copilot-cost-tracker",
          "title": "Copilot Cost",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "copilot-cost-tracker": [
        {
          "type": "webview",
          "id": "copilotCostTracker.dashboard",
          "name": "Dashboard"
        }
      ]
    },
    "commands": [
      {
        "command": "copilotCostTracker.refresh",
        "title": "Refresh Cost Data",
        "category": "Copilot Cost",
        "icon": "$(refresh)"
      },
      {
        "command": "copilotCostTracker.resetSession",
        "title": "Reset Session Tracking",
        "category": "Copilot Cost"
      },
      {
        "command": "copilotCostTracker.openDashboard",
        "title": "Open Dashboard",
        "category": "Copilot Cost"
      },
      {
        "command": "copilotCostTracker.openSettings",
        "title": "Open Settings",
        "category": "Copilot Cost"
      }
    ],
    "configuration": {
      "title": "Copilot Cost Tracker",
      "properties": {
        "copilotCostTracker.pollingInterval": {
          "type": "number",
          "default": 10,
          "minimum": 2,
          "maximum": 300,
          "description": "How often to poll for new cost data (in seconds)."
        },
        "copilotCostTracker.budget.session.warning": {
          "type": "number",
          "default": 5,
          "description": "Session cost warning threshold (USD). Shows yellow indicator."
        },
        "copilotCostTracker.budget.session.limit": {
          "type": "number",
          "default": 8,
          "description": "Session cost limit threshold (USD). Shows red indicator."
        },
        "copilotCostTracker.budget.daily.warning": {
          "type": "number",
          "default": 20,
          "description": "Daily cost warning threshold (USD)."
        },
        "copilotCostTracker.budget.daily.limit": {
          "type": "number",
          "default": 50,
          "description": "Daily cost limit threshold (USD)."
        },
        "copilotCostTracker.budget.weekly.warning": {
          "type": "number",
          "default": 25,
          "description": "Weekly cost warning threshold (USD)."
        },
        "copilotCostTracker.budget.weekly.limit": {
          "type": "number",
          "default": 50,
          "description": "Weekly cost limit threshold (USD)."
        },
        "copilotCostTracker.pricingOverrides": {
          "type": "object",
          "default": {},
          "description": "Override pricing for specific models. Keys are model name patterns, values are objects with input/output/cached/cacheWrite rates per 1M tokens.",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "input": {
                "type": "number"
              },
              "output": {
                "type": "number"
              },
              "cached": {
                "type": "number"
              },
              "cacheWrite": {
                "type": "number"
              }
            }
          }
        },
        "copilotCostTracker.costDataSource": {
          "type": "string",
          "enum": [
            "agent-traces-only",
            "with-fallback"
          ],
          "default": "agent-traces-only",
          "enumDescriptions": [
            "Use only agent-traces.db (recommended — accurate cache read/write data)",
            "Fall back to debug-logs when agent-traces unavailable (cache write data will be missing)"
          ],
          "description": "Where to read cost data from. agent-traces.db is the recommended source as it includes accurate cache read/write token counts."
        },
        "copilotCostTracker.history.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable persistent cost history. Saves daily aggregates to files so data survives agent-traces.db resets."
        },
        "copilotCostTracker.history.retentionDays": {
          "type": "number",
          "default": 90,
          "minimum": 7,
          "maximum": 365,
          "description": "Number of days to retain daily cost history files."
        },
        "copilotCostTracker.history.scrapeInterval": {
          "type": "number",
          "default": 30,
          "minimum": 1,
          "maximum": 600,
          "description": "Number of poll cycles between history scrapes. At default 10s polling, 30 cycles = ~5 minutes between file writes."
        },
        "copilotCostTracker.displayCurrency.code": {
          "type": "string",
          "default": "",
          "description": "ISO currency code to show on hover (e.g. NOK, EUR, GBP). Leave empty to disable."
        },
        "copilotCostTracker.displayCurrency.rate": {
          "type": "number",
          "default": 1,
          "minimum": 0,
          "description": "Exchange rate: 1 USD = X units of your display currency."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.mjs",
    "watch": "node esbuild.config.mjs --watch",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^20.14.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.21.0",
    "eslint": "^9.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0"
  }
}
