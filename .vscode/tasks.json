{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "watch",
      "path": "extension",
      "label": "npm: watch - extension",
      "isBackground": true,
      "problemMatcher": {
        "owner": "esbuild",
        "fileLocation": ["relative", "${workspaceFolder}/extension"],
        "pattern": {
          "regexp": "^✘ \\[ERROR\\] (.+?)\\n\\n\\s+(.+?):(\\d+):(\\d+):",
          "message": 1,
          "file": 2,
          "line": 3,
          "column": 4
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "Watching for changes\\.\\.\\."
        }
      }
    },
    {
      "type": "npm",
      "script": "build",
      "path": "extension",
      "label": "npm: build - extension",
      "problemMatcher": []
    }
  ]
}
